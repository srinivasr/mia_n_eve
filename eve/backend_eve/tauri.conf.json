{
  "productName": "mia_n_eve",
  "version": "0.1.0",
  "identifier": "com.mianeve.dev",
  "build": {
    "beforeDevCommand": "npm run dev --prefix UI_eve",
    "beforeBuildCommand": "npm run build --prefix UI_eve",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../UI_eve/dist"
  },
  "app": {
    "windows": [
      {
        "title": "mia_n_eve",
        "fullscreen": true,
        "transparent": false,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}