{
  "productName": "mia_n_eve",
  "version": "0.1.0",
  "identifier": "com.mianeve.dev",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd ../UI_eve && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../UI_eve/dist"
  },
  "app": {
    "windows": [
      {
        "title": "mia_n_eve",
        "fullscreen": true,
        "transparent": false,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}